# Copy this file to .env (which is gitignored) and fill in your values.
# run_portfolio.sh auto-loads .env on startup; never commit real secrets.

# FRED — free key at https://fredaccount.stlouisfed.org/apikeys
# Unlocks the real-yield / HY-spread / 2s10s-curve macro factors.
FRED_API_KEY=

# LLM narrator (optional). When set, swaps the deterministic narrator for an LLM.
# LLM_API_KEY=
# LLM_MODEL=claude-haiku-4-5-20251001
# LLM_PROVIDER=anthropic

# Telegram daily-report push (optional).
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Flask CSRF secret — set a real random value in production.
# SECRET_KEY=

# Scheduler (optional).
# ENABLE_SCHEDULER=1
# REPORT_HOUR=8
# REPORT_MINUTE=0
